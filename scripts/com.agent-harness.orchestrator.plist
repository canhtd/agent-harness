<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.agent-harness.orchestrator</string>

	<key>ProgramArguments</key>
	<array>
		<string>__REPO_PATH__/start.sh</string>
	</array>

	<key>WorkingDirectory</key>
	<string>__REPO_PATH__</string>

	<key>KeepAlive</key>
	<true/>

	<key>ThrottleInterval</key>
	<integer>10</integer>

	<key>StandardOutPath</key>
	<string>__HOME__/.agent-harness/logs/launchd-stdout.log</string>

	<key>StandardErrorPath</key>
	<string>__HOME__/.agent-harness/logs/launchd-stderr.log</string>

	<key>EnvironmentVariables</key>
	<dict>
		<key>PATH</key>
		<string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
	</dict>
</dict>
</plist>
